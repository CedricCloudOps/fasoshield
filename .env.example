# FasoShield configuration (12-factor, prefix FASOSHIELD_)

# Comma-separated API keys for mobile agents; empty disables auth (dev only).
FASOSHIELD_API_KEYS=

# PostgreSQL in production; empty falls back to a local SQLite file.
FASOSHIELD_DATABASE_URL=

# Storage locations (defaults are relative to the project root).
#FASOSHIELD_DATA_DIR=/var/lib/fasoshield
#FASOSHIELD_SIGNATURES_DIR=/etc/fasoshield/signatures

# Upload cap for POST /v1/scan (bytes).
#FASOSHIELD_MAX_UPLOAD_BYTES=209715200
