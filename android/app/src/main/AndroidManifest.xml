<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Reputation lookups and signature synchronisation. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Post detection alerts (runtime prompt on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Re-arm the scan schedule after reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      QUERY_ALL_PACKAGES is required to enumerate every installed application
      for a security scanner. Google Play grants this to antivirus apps under
      the "device security" permitted use; it must be declared and justified.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".FasoShieldApp"
        android:allowBackup="false"
        android:icon="@drawable/ic_shield"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FasoShield">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fires when a new package is installed or replaced. -->
        <receiver
            android:name=".work.PackageEventReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- Re-schedules periodic work after a reboot. -->
        <receiver
            android:name=".work.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
